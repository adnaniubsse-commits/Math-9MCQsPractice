<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover, user-scalable=yes">
    <title>Teachers Academy Bahawalpur | 9th Math ALP 2026</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            -webkit-tap-highlight-color: transparent;
        }

        body {
            background: linear-gradient(145deg, #f0f4ff 0%, #d9e2fb 100%);
            font-family: 'Segoe UI', 'Poppins', system-ui, -apple-system, 'Roboto', sans-serif;
            padding: 20px 16px 40px;
            min-height: 100vh;
        }

        .container {
            max-width: 800px;
            margin: 0 auto;
            background: rgba(255, 255, 255, 0.94);
            backdrop-filter: blur(2px);
            border-radius: 48px 32px 48px 32px;
            box-shadow: 0 25px 45px rgba(0, 0, 0, 0.15), 0 0 0 1px rgba(255, 255, 255, 0.5);
            overflow: hidden;
            padding: 24px 20px 32px;
            transition: all 0.2s ease;
        }

        .academy-header {
            text-align: center;
            margin-bottom: 28px;
        }
        .logo-area {
            display: flex;
            flex-direction: column;
            align-items: center;
            margin-bottom: 15px;
            position: relative;
        }
        .logo-preview {
            width: 110px;
            height: 110px;
            background: #f8f3e0;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            box-shadow: 0 12px 18px -8px rgba(0,0,0,0.2);
            border: 3px solid #ffd966;
            overflow: hidden;
            margin-bottom: 8px;
            background: white;
        }
        .logo-preview img {
            max-width: 95%;
            max-height: 95%;
            object-fit: contain;
        }
        .logo-placeholder {
            font-size: 2.5rem;
        }
        .upload-logo-btn {
            background: #e6b422;
            border: none;
            padding: 6px 16px;
            border-radius: 40px;
            font-size: 0.75rem;
            font-weight: bold;
            cursor: pointer;
            margin-top: 5px;
            color: #2c2b28;
        }
        .permanent-logo-badge {
            font-size: 0.65rem;
            color: #2e7d32;
            margin-top: 4px;
        }
        .welcome-text {
            font-size: 1.8rem;
            font-weight: 800;
            background: linear-gradient(135deg, #1e3c72, #2b5e8a);
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
        }
        .academy-name {
            font-size: 1.1rem;
            font-weight: 700;
            color: #b8860b;
            letter-spacing: 1px;
        }
        .alp-badge {
            background: #2e7d32;
            color: white;
            font-size: 0.7rem;
            display: inline-block;
            padding: 4px 12px;
            border-radius: 30px;
            margin-top: 8px;
        }
        .btn-group {
            display: flex;
            gap: 20px;
            justify-content: center;
            margin: 30px 0 20px;
            flex-wrap: wrap;
        }
        .btn {
            border: none;
            font-weight: 700;
            padding: 14px 30px;
            border-radius: 60px;
            font-size: 1.2rem;
            cursor: pointer;
            background: white;
            box-shadow: 0 5px 12px rgba(0,0,0,0.1);
            transition: 0.2s;
            font-family: inherit;
            width: 170px;
        }
        .btn-teacher { background: #2c3e66; color: white; border: 1px solid #ffcd7e; }
        .btn-student { background: #e6b422; color: #2c2b28; }
        .btn:active { transform: scale(0.96); }
        .form-card {
            background: #fefcf5;
            border-radius: 32px;
            padding: 20px;
            margin-top: 20px;
            box-shadow: 0 8px 20px rgba(0,0,0,0.05);
        }
        input, select {
            width: 100%;
            padding: 14px 16px;
            margin: 8px 0 16px;
            border-radius: 60px;
            border: 1px solid #ccc;
            font-size: 1rem;
            background: white;
        }
        .warning {
            color: #c0392b;
            font-size: 0.7rem;
            margin-top: -12px;
            margin-bottom: 12px;
        }
        .chapter-grid {
            display: flex;
            flex-wrap: wrap;
            gap: 12px;
            margin: 20px 0;
            max-height: 480px;
            overflow-y: auto;
        }
        .chapter-btn {
            background: linear-gradient(135deg, #e9ecf5, #dfe4f0);
            border: none;
            padding: 12px 16px;
            border-radius: 50px;
            font-weight: 600;
            color: #1e4668;
            flex: 1 0 auto;
            min-width: 160px;
            cursor: pointer;
            font-size: 0.85rem;
            transition: 0.1s;
        }
        .mcq-question {
            background: white;
            border-radius: 28px;
            padding: 18px;
            margin-bottom: 18px;
            border-left: 8px solid #e6b422;
            box-shadow: 0 4px 10px rgba(0,0,0,0.05);
        }
        .options label {
            display: block;
            margin: 8px 0;
            cursor: pointer;
            padding: 6px 10px;
            border-radius: 40px;
            background: #f9f9f9;
        }
        .submit-test {
            background: #2e7d32;
            color: white;
            width: 100%;
            padding: 16px;
            font-size: 1.2rem;
            border-radius: 44px;
            margin: 20px 0 10px;
        }
        .result-card {
            background: linear-gradient(120deg, #f9f3e0, #fff2db);
            border-radius: 28px;
            padding: 24px;
            margin-top: 20px;
            border: 2px solid #ffcd7e;
        }
        .back-btn {
            background: #6c757d;
            margin-top: 18px;
        }
        .teacher-data {
            background: #1e2a3a;
            color: #eee;
            border-radius: 28px;
            padding: 18px;
            overflow-x: auto;
            font-size: 0.8rem;
        }
        table { width: 100%; border-collapse: collapse; }
        th, td { padding: 8px; text-align: left; border-bottom: 1px solid #ddd; }
        .download-pdf-btn {
            background: #dc3545;
            color: white;
            padding: 10px 20px;
            border-radius: 40px;
            border: none;
            margin: 15px 0;
            font-weight: bold;
            cursor: pointer;
        }
        .academy-footer {
            font-size: 0.7rem;
            text-align: center;
            margin-top: 20px;
            color: #5a6e8a;
        }
        .score-badge {
            background: #2c3e66;
            color: white;
            border-radius: 30px;
            padding: 4px 12px;
            font-size: 0.7rem;
        }
        .alp-note {
            background: #e8f0fe;
            padding: 8px 12px;
            border-radius: 20px;
            font-size: 0.7rem;
            text-align: center;
            margin-bottom: 10px;
        }
        .flex-between {
            display: flex;
            align-items: center;
            gap: 12px;
        }
    </style>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
</head>
