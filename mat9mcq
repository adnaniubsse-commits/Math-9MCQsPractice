    // Load data from localStorage
    function loadData() {
        const stored = localStorage.getItem("TeachersAcademy_ALP_Full");
        if(stored) {
            try {
                const data = JSON.parse(stored);
                studentsData = data.studentsData || [];
                chapterAttempts = data.chapterAttempts || {};
                reattemptRequests = data.reattemptRequests || {};
                academyLogoURL = data.academyLogoURL || null;
