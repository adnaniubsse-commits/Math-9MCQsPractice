    function hasRequested(phone, chapId) { return reattemptRequests[`${phone}_${chapId}`] === true; }
    function setRequest(phone, chapId, val) { reattemptRequests[`${phone}_${chapId}`] = val; saveData(); }

    function render() {
        const root = document.getElementById("appRoot");
        if(currentView === "welcome") root.innerHTML = renderWelcome();
        else if(currentView === "teacherPanel") root.innerHTML = renderTeacherPanel();
        else if(currentView === "studentForm") root.innerHTML = renderStudentForm();
        else if(currentView === "testPanel") root.innerHTML = renderTestPanel();
        else if(currentView === "resultPanel") root.innerHTML = renderResultPanel();
        attachEvents();
    }

