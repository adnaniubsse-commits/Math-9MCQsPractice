            </div>
            <div class="btn-group">
                <button class="btn btn-teacher" data-action="teacher">👨‍🏫 Teacher</button>
                <button class="btn btn-student" data-action="student">📚 Student</button>
            </div>
            <div class="academy-footer">Chapter-wise MCQ tests | Result cards | 2 attempts per chapter</div>
        `;
    }

    function renderTeacherPanel() {
        return `<div class="form-card"><h3>🔐 Teacher Dashboard (Password: 2247)</h3><input type="password" id="teacherPass" placeholder="Enter password"><button id="verifyTeacherBtn" class="btn" style="background:#2c3e66;color:white;">Unlock & View Data</button><div id="teacherDataView"></div></div><button class="btn back-btn" data-action="backWelcome">⬅ Back</button>`;
    }

    function renderStudentForm() {
        return `<div class="form-card"><h3>📝 Student Registration - ALP 2026</h3><input type="text" id="studentName" placeholder="Full Name"><input type="text" id="fatherName" placeholder="Father Name"><input type="tel" id="phoneNum" placeholder="03XX-XXXXXXX"><div class="warning">⚠️ Use correct number. Result card will be sent via SMS simulation.</div><input type="text" id="schoolName" placeholder="School Name"><input type="text" id="cityName" placeholder="City"><button id="registerStudentBtn" class="btn" style="background:#e6b422;">✅ Start Practice</button><button class="btn back-btn" data-action="backWelcome">Back</button></div>`;
    }

    function renderTestPanel() {
        if(!currentStudent) return "<div>Error</div>";
        if(!currentChapter) {
            let chapHtml = `<div class="form-card"><h3>📘 Salam ${escapeHtml(currentStudent.name)}</h3><div class="alp-note">📌 ALP 2026 Chapter-wise MCQ Tests | Max 2 attempts per chapter</div><div class="chapter-grid">`;
            for(let [key, chap] of Object.entries(MATH_ALP_2026)) {
                let left = getAttemptsLeft(currentStudent.phone, key);
                let status = left===0 ? "❌ Finished" : left===1 ? "⚠️ 1 left" : "✅ 2 left";
                let req = hasRequested(currentStudent.phone, key) ? " 🔔 Request Pending" : "";
                chapHtml += `<button data-chapter="${key}" class="chapter-btn" ${left===0 ? 'style="opacity:0.6;"' : ''}>${chap.name}<br><span class="score-badge">${status}${req}</span></button>`;
            }
            chapHtml += `</div><button class="btn back-btn" data-action="backWelcome">🏠 Home</button></div>`;
            return chapHtml;
        } else {
            let chap = MATH_ALP_2026[currentChapter];
            let html = `<div class="form-card"><h3>${chap.name} (ALP 2026)</h3><p>✅ Attempted: ${userAnswers.filter(a=>a!==-1).length}/${chap.questions.length}</p>`;
            chap.questions.forEach((q, idx) => {
                let selected = userAnswers[idx] !== undefined ? userAnswers[idx] : -1;
                html += `<div class="mcq-question"><strong>${idx+1}. ${escapeHtml(q.text)}</strong><div class="options">`;
                q.options.forEach((opt, optIdx) => {
                    let letter = String.fromCharCode(65+optIdx);
                    html += `<label><input type="radio" name="q${idx}" value="${optIdx}" ${selected===optIdx ? 'checked' : ''}> ${letter}. ${escapeHtml(opt)}</label>`;
                });
                html += `</div></div>`;
            });
            html += `<button id="finalSubmitTest" class="btn submit-test">📊 Submit Test & Get Resultcard</button><button class="btn back-btn" data-action="backToChapters">◀ Back to Chapters</button></div>`;
            return html;
        }
    }

    function renderResultPanel() {
        if(!resultData) return "<div>Error</div>";
        let chap = MATH_ALP_2026[resultData.chapterId];
        let logoImg = academyLogoURL ? `<img src="${academyLogoURL}" style="width:50px; border-radius:50%; margin-right:10px;">` : "🏫";
        let html = `<div class="result-card"><div class="flex-between">${logoImg}<div><strong>Teachers Academy Bahawalpur</strong><br><small>ALP 2026 Result</small></div></div><h3>🎓 Result Card</h3><p><strong>Student:</strong> ${escapeHtml(currentStudent.name)}<br><strong>Father:</strong> ${escapeHtml(currentStudent.father)}<br><strong>Contact:</strong> ${currentStudent.phone}<br><strong>School:</strong> ${escapeHtml(currentStudent.school)}</p><p><strong>Chapter:</strong> ${chap.name}</p><p><strong>Score:</strong> ${resultData.score} / ${resultData.total}</p><p>✅ Correct: ${resultData.correctCount} &nbsp;| ❌ Wrong: ${resultData.wrongCount}</p>`;
        if(resultData.wrongList.length > 0) {
            html += `<div style="margin-top:12px;"><strong>⚠️ Incorrect Attempts & Correct Options:</strong><ul>`;
            resultData.wrongList.forEach(w => {
                html += `<li>Q${w.qno}: ${escapeHtml(w.questionText)}<br> ➤ Your: ${escapeHtml(w.selected)} &nbsp; ✅ Correct: ${escapeHtml(w.correctOption)}</li>`;
            });
            html += `</ul></div>`;
        } else { html += `<p>🏆 Perfect score! Well done.</p>`; }
        let left = getAttemptsLeft(currentStudent.phone, resultData.chapterId);
        let requested = hasRequested(currentStudent.phone, resultData.chapterId);
        if(left > 0 && !requested) html += `<button id="reattemptBtn" class="btn" style="background:#f39c12;">🔄 Re-attempt (${left} left)</button>`;
        else if(left === 0 && !requested) html += `<button id="requestReattemptBtn" class="btn" style="background:#9b59b6;">📢 Request Re-attempt to Teacher</button>`;
        else if(requested) html += `<div style="background:#ffe0b3;padding:10px;border-radius:30px;">⏳ Request sent to teacher. Approval pending.</div>`;
        html += `<button class="btn back-btn" data-action="backToChaptersFromResult">📚 More Chapters</button><button class="btn back-btn" data-action="backWelcome">🏠 Home</button></div>`;
        return html;
    }

    function showTeacherDataAfterAuth() {
        let html = `<h4>📊 Student Records (${studentsData.length} registered)</h4><table style="width:100%"><tr><th>Name</th><th>Phone</th><th>School</th></tr>`;
        studentsData.forEach(s => { html += `<tr><td>${escapeHtml(s.name)}</td><td>${s.phone}</td><td>${escapeHtml(s.school)}</td></tr>`; });
        html += `</table><h4>🔄 Reattempt Requests</h4><ul>`;
        let hasReq = false;
        for(let [key, val] of Object.entries(reattemptRequests)) {
            if(val === true) {
                hasReq = true;
                let [phone, chapId] = key.split("_");
                let student = studentsData.find(s => s.phone === phone);
                let chapName = MATH_ALP_2026[chapId]?.name || chapId;
                html += `<li>${student?.name || phone} - Request for ${chapName} <button data-clear-req="${key}" class="approveReqBtn" style="background:green;color:white;padding:2px 10px;border-radius:20px;">✅ Approve & Reset</button></li>`;
            }
        }
        if(!hasReq) html += `<li>No pending requests</li>`;
        html += `</ul><button id="downloadPDFBtn" class="download-pdf-btn">📄 Download Student Data PDF</button>`;
        document.getElementById("teacherDataView").innerHTML = html;
        document.querySelectorAll(".approveReqBtn").forEach(btn => {
            btn.onclick = () => {
                let key = btn.getAttribute("data-clear-req");
                if(key) { setRequest(key.split("_")[0], key.split("_")[1], false); chapterAttempts[key] = 0; saveData(); showTeacherDataAfterAuth(); alert("Approved! Student can attempt again."); }
            };
        });
        document.getElementById("downloadPDFBtn")?.addEventListener("click", async () => {
            const { jsPDF } = window.jspdf;
            const doc = new jsPDF();
            doc.text("Teachers Academy Bahawalpur - Student Report (ALP 2026)", 14, 20);
            doc.text(`Total Students: ${studentsData.length}`, 14, 35);
            let y = 45;
            studentsData.forEach((s, i) => {
                if(y > 270) { doc.addPage(); y = 20; }
                doc.text(`${i+1}. ${s.name} | ${s.phone} | ${s.school}, ${s.city}`, 14, y);
                y+=7;
            });
            doc.save("Students_ALP_2026.pdf");
        });
    }

    function attachEvents() {
        // Permanent logo upload handler
        document.getElementById("triggerLogoUpload")?.addEventListener("click", () => { document.getElementById("logoUploadInput").click(); });
        document.getElementById("logoUploadInput")?.addEventListener("change", (e) => {
            let file = e.target.files[0];
            if(file) { 
                let reader = new FileReader(); 
                reader.onload = (ev) => { 
                    academyLogoURL = ev.target.result; 
                    saveData(); 
                    render(); 
                    alert("✅ Logo saved permanently! It will appear every time you open this page.");
                }; 
                reader.readAsDataURL(file); 
            }
        });
        document.getElementById("verifyTeacherBtn")?.addEventListener("click", () => {
            let pass = document.getElementById("teacherPass").value;
            if(pass === "2247") showTeacherDataAfterAuth();
            else alert("Wrong password!");
        });
        document.getElementById("registerStudentBtn")?.addEventListener("click", () => {
            let name = document.getElementById("studentName").value.trim();
            let father = document.getElementById("fatherName").value.trim();
            let phone = document.getElementById("phoneNum").value.trim();
            let school = document.getElementById("schoolName").value.trim();
            let city = document.getElementById("cityName").value.trim() || "Bahawalpur";
            if(!name || !father || !phone || !school) { alert("Fill all fields"); return; }
            if(!/^03\d{2}-\d{7}$/.test(phone)) { alert("Use 03XX-XXXXXXX format"); return; }
            let samePhoneCount = studentsData.filter(s => s.phone === phone).length;
            if(samePhoneCount >= 3) { alert("This phone number already used by 3 students."); return; }
            let newStd = { id: Date.now(), name, father, phone, school, city, regDate: new Date().toISOString() };
            studentsData.push(newStd);
            saveData();
            currentStudent = newStd;
            currentChapter = null;
            currentView = "testPanel";
            render();
        });
        document.querySelectorAll("[data-chapter]").forEach(btn => {
            btn.onclick = () => {
                let chapId = btn.getAttribute("data-chapter");
                if(getAttemptsLeft(currentStudent.phone, chapId) <= 0 && !hasRequested(currentStudent.phone, chapId)) { alert("No attempts left! Request reattempt from Teacher section."); return; }
                currentChapter = chapId;
                userAnswers = new Array(MATH_ALP_2026[chapId].questions.length).fill(-1);
                resultData = null;
                render();
            };
        });
        document.getElementById("finalSubmitTest")?.addEventListener("click", () => {
            let qs = MATH_ALP_2026[currentChapter].questions;
            for(let i=0; i<qs.length; i++) { let sel = document.querySelector(`input[name="q${i}"]:checked`); if(sel) userAnswers[i] = parseInt(sel.value); else userAnswers[i] = -1; }
            if(userAnswers.includes(-1)) { alert("⚠️ Please attempt all MCQs before submitting!"); render(); return; }
            let correctCount = 0, wrongList = [];
            qs.forEach((q, i) => {
                if(userAnswers[i] === q.correct) correctCount++;
                else wrongList.push({ qno: i+1, questionText: q.text, selected: q.options[userAnswers[i]], correctOption: q.options[q.correct] });
            });
            resultData = { chapterId: currentChapter, total: qs.length, score: correctCount, correctCount, wrongCount: qs.length-correctCount, wrongList };
            incrementAttempt(currentStudent.phone, currentChapter);
            alert(`📱 Result card sent to ${currentStudent.phone}\nScore: ${correctCount}/${qs.length}\nTeachers Academy Bahawalpur`);
            currentView = "resultPanel";
            render();
        });
        document.getElementById("reattemptBtn")?.addEventListener("click", () => { if(getAttemptsLeft(currentStudent.phone, resultData.chapterId) > 0) { currentChapter = resultData.chapterId; userAnswers.fill(-1); resultData = null; currentView = "testPanel"; render(); } else alert("No reattempt left."); });
        document.getElementById("requestReattemptBtn")?.addEventListener("click", () => { setRequest(currentStudent.phone, resultData.chapterId, true); alert("Request sent to Teacher!"); render(); });
        document.querySelectorAll("[data-action='backWelcome']").forEach(el => el.onclick = () => { currentView = "welcome"; currentStudent = null; currentChapter = null; render(); });
        document.querySelectorAll("[data-action='backToChapters']").forEach(el => el.onclick = () => { currentChapter = null; render(); });
        document.querySelectorAll("[data-action='backToChaptersFromResult']").forEach(el => el.onclick = () => { currentChapter = null; resultData = null; render(); });
        document.querySelectorAll("[data-action='teacher']").forEach(el => el.onclick = () => { currentView = "teacherPanel"; render(); });
        document.querySelectorAll("[data-action='student']").forEach(el => el.onclick = () => { currentView = "studentForm"; render(); });
    }

    function escapeHtml(str) { if(!str) return ''; return str.replace(/[&<>]/g, m => ({'&':'&amp;','<':'&lt;','>':'&gt;'})[m]); }
    loadData();
    render();
</script>
</body>
</html>
